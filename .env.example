# Copy this file to .env and fill in your key.
#   cp .env.example .env
#
# Get a free key at https://openrouter.ai/keys — no card needed for free models.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# The auto-router picks whichever free model is up right now. Pinning one
# specific free slug means your demo dies the day it gets rate-limited.
HMA_MODEL=openrouter/free

# Findings below this confidence are shown but never auto-applied.
HMA_AUTO_APPLY=0.90
